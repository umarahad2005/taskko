# Taskko backend environment variables (Vercel project settings).
# Copy to `.env.local` for local dev. NEVER commit real values (NFR-2).

# --- Gemini API (Generative Language) — server-side API key ---
# Create in your GCP project (APIs & Services → Credentials → Create API key)
# with the Gemini API (generativelanguage.googleapis.com) enabled. Server-only.
GEMINI_API_KEY=your-gemini-api-key
# Optional model override (default gemini-2.5-flash):
# GEMINI_MODEL=gemini-2.5-flash

# Firebase service account JSON for the Admin SDK (token verification).
# Paste the FULL service-account JSON as a single-line string (escaped),
# OR base64-encode the JSON file and paste that (lib/firebaseAdmin.ts accepts both).
# Get it from: Firebase console → Project settings → Service accounts → Generate new private key.
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}

# Comma-separated list of allowed CORS origins (Flutter web/admin web).
# For the Android app (no Origin header) requests are allowed regardless.
# Example: https://taskko-admin.vercel.app,http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000

# ---------------------------------------------------------------------------
# Admin web UI (M8) — Firebase Web SDK config.
# These are PUBLIC by design (NEXT_PUBLIC_* is inlined into the browser bundle).
# They are NOT secrets: the admin claim and the Gemini key are enforced/held
# server-side (NFR-2, FR-11.9). Get them from:
# Firebase console → Project settings → General → "Your apps" → Web app config.
NEXT_PUBLIC_FIREBASE_API_KEY=your-web-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxx

# Optional: where the "Switch to student app" top-bar link points (FR-11.2).
# NEXT_PUBLIC_STUDENT_APP_URL=https://app.taskko.app

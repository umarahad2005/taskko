rules_version = '2';

// Taskko Cloud Firestore Security Rules (SRS §7.1, NFR-2).
// Principle: default deny; users touch only their own data; admin-only data
// requires the admin custom claim. Admin enforcement also exists server-side
// in the Vercel API — these rules are the second line of defense for direct
// client access.
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }
    function isAdmin() {
      return isSignedIn() &&
        (request.auth.token.admin == true || request.auth.token.isAdmin == true);
    }

    // A user owns everything under their own document subtree.
    match /users/{uid} {
      allow read, write: if isOwner(uid) || isAdmin();

      match /{document=**} {
        allow read, write: if isOwner(uid) || isAdmin();
      }
    }

    // App configuration (ranks, badges, feature flags) — read-only to clients,
    // writable only by admins (typically via the server).
    match /config/{doc} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Squads — members may read; membership/leaderboard writes go through the
    // server. Keep client writes closed for now.
    match /squads/{squadId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Moderation queue — admin only.
    match /moderation/{itemId} {
      allow read, write: if isAdmin();
    }

    // Everything else is denied by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
